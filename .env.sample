# Embedding model (Genkit embedder reference)
EMBEDDER_MODEL=googleai/text-embedding-005

# Google AI API key (required for googleai models)
GOOGLE_API_KEY=

# OpenAI-compatible server (LM Studio, Ollama, LocalAI, vLLM, etc.)
OPENAI_COMPAT_URL=http://localhost:1234/v1
OPENAI_COMPAT_PROVIDER=lmstudio
OPENAI_COMPAT_MODEL=nomic-embed-text-v1.5
OPENAI_COMPAT_API_KEY=
