ADDR=:3000

# API authentication (comma-separated keys)
API_KEYS=

# Rate limiting (per IP)
RATE_LIMIT=10
RATE_BURST=20

# CORS (comma-separated origins, empty = disabled)
# CORS_ORIGINS=http://localhost:3000,https://app.example.com

# Embedding model (Genkit embedder reference)
EMBEDDER_MODEL=googleai/text-embedding-005

# Google AI API key (required for googleai models)
GOOGLE_API_KEY=

# LM Studio (for local embedding models)
LMSTUDIO_URL=http://localhost:1234/v1
LMSTUDIO_EMBEDDER_MODEL=
